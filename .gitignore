### --- 1. SECURITY & SECRETS (CRITICAL) ---
# Never commit actual credentials. Use .env.example for templates.
.env
.env.local
.env.*.local
*.env
secrets.py
instance/
.python-version
.netrc
*.pem
*.key
*.pub
auth.json

### --- 2. MACOS SPECIFIC (PREVENT METADATA LEAKS) ---
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes
.fseventsd
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk
*.icu

### --- 3. DOCKER & CONTAINERS ---
# Prevent local data volumes from being committed
pgdata/
mysql_data/
redisdata/
mongo_data/
.docker/
# Ignore local overrides that might contain dev-specific secrets
docker-compose.override.yml

### --- 4. PYTHON ARTIFACTS ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

### --- 5. VIRTUAL ENVIRONMENTS ---
# Docker handles dependencies; keep local venvs out of Git
venv/
.venv/
ENV/
env.bak/
venv.bak/

### --- 6. TESTING & COVERAGE ---
.target/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/
htmlcov/

### --- 7. DATABASES & LOGS ---
*.db
*.sqlite3
*.sqlite
*.log
logs/
*.swp
*.swo

### --- 8. IDE SPECIFIC (OPTIONAL BUT RECOMMENDED) ---
.vscode/
.idea/
*.swp
*.swo
.project
.pydevproject
.settings/