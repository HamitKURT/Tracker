# =========================
# 🔐 SECURITY
# =========================
ELASTIC_PASSWORD=changeme
KIBANA_SYSTEM_PASSWORD=changeme
KIBANA_USERNAME=kibana_system

# =========================
# 🌐 SERVICE URLS
# =========================
ELASTIC_URL=http://elasticsearch:9200
KIBANA_URL=http://kibana:5601
LOGSERVER_URL=http://log-server:8084

# =========================
# ⚙️ ELASTIC SETTINGS
# =========================
DISCOVERY_TYPE=single-node
XPACK_SECURITY_ENABLED=true
XPACK_HTTP_SSL_ENABLED=false
XPACK_ENROLLMENT_ENABLED=true
ES_JAVA_OPTS=-Xms1g -Xmx6g

# =========================
# 🌐 PORTS
# =========================
REDIS_PORT=6379
ELASTICSEARCH_PORT=9200
KIBANA_PORT=5601
WEB_APP_PORT=8081
LOG_SERVER_PORT=8084

# =========================
# 🔴 REDIS
# =========================
REDIS_HOST=redis

# =========================
# 📊 ELASTIC INDEX
# =========================
ELASTIC_INDEX=selenium-events

# =========================
# ⚙️ WORKER
# =========================
BATCH_SIZE=50
MAX_WAIT_TIME=2.0

# =========================
# 🧪 SELENIUM
# =========================
CHROMEDRIVER_PATH=/usr/bin/chromedriver

# =========================
# 🐛 DEBUG
# =========================
DEBUG=false
