# =============================================================================
# 🔐 SECURITY
# Elasticsearch ve Kibana için güçlü parolalar belirleyin.
# Varsayılan "changeme" değerlerini production ortamında MUTLAKA değiştirin.
# =============================================================================
ELASTIC_PASSWORD=changeme
ELASTIC_USERNAME=elastic
KIBANA_SYSTEM_PASSWORD=changeme
KIBANA_USERNAME=kibana_system

# =============================================================================
# 🌐 SERVICE URLS
# Container isimleri docker-compose servis adlarıyla eşleşmelidir.
# Bu değerleri değiştirmeniz genellikle gerekmez.
# =============================================================================
ELASTIC_URL=http://elasticsearch:9200
KIBANA_URL=http://kibana:5601
LOGSERVER_URL=http://log-server:8084

# =============================================================================
# ⚙️ ELASTICSEARCH SETTINGS
# DISCOVERY_TYPE: "single-node" tek düğüm için, cluster için "zen" kullanın.
# XPACK_HTTP_SSL_ENABLED: Geliştirme ortamında false bırakın; prod'da true yapın.
# ES_JAVA_OPTS: Heap boyutunu sunucu RAM'inin %50'sini geçmeyecek şekilde ayarlayın.
#   Öneri: 4 GB RAM → -Xms512m -Xmx2g | 16 GB RAM → -Xms1g -Xmx6g
# =============================================================================
DISCOVERY_TYPE=single-node
XPACK_SECURITY_ENABLED=true
XPACK_HTTP_SSL_ENABLED=false
XPACK_ENROLLMENT_ENABLED=true
ES_JAVA_OPTS=-Xms1g -Xmx4g

# =============================================================================
# 🌐 PORTS
# Host üzerindeki port çakışmalarını önlemek için değiştirilebilir.
# Değiştirirseniz ilgili servisin PORT değerini de güncellemeyi unutmayın.
# =============================================================================
REDIS_PORT=6379
ELASTICSEARCH_PORT=9200
KIBANA_PORT=5601
WEB_APP_PORT=8081
LOG_SERVER_PORT=8084

# =============================================================================
# 🔴 REDIS
# REDIS_HOST: Docker ağında servis adıyla iletişim kurulur, IP kullanmayın.
# Gerekirse REDIS_PASSWORD ekleyerek kimlik doğrulama aktif edebilirsiniz.
# =============================================================================
REDIS_HOST=redis
# REDIS_PASSWORD=          # Opsiyonel: Redis AUTH şifresi (boş bırakılırsa devre dışı)

# =============================================================================
# 📊 ELASTICSEARCH INDEX
# Logların yazılacağı index adı. Kibana'da bu isimle arama yapılır.
# İsim küçük harf, tire ve alt çizgi içerebilir; boşluk kullanmayın.
# =============================================================================
ELASTIC_INDEX=selenium-events
REDIS_QUEUE_KEY=selenium_logs

# =============================================================================
# ⚙️ LOG WORKER — Batch Ayarları
# BATCH_SIZE: Tek seferinde Elasticsearch'e gönderilecek maksimum log sayısı.
#   Yüksek trafik → 100-200 | Düşük trafik → 25-50
# MAX_WAIT_TIME: Batch dolmasa bile maksimum bekleme süresi (saniye).
#   Düşürülürse gerçek zamanlılık artar, yük hafif artar.
# =============================================================================
BATCH_SIZE=50
MAX_WAIT_TIME=2.0

# =============================================================================
# 🧪 SELENIUM TEST
# CHROMEDRIVER_PATH: Selenium testlerinin kullandığı ChromeDriver yolu.
# Dockerfile içinde kurulur; değiştirmeniz genellikle gerekmez.
# =============================================================================
CHROMEDRIVER_PATH=/usr/bin/chromedriver

# =============================================================================
# 🐛 DEBUG
# true yapıldığında servisler detaylı log çıktısı üretir.
# Production ortamında false bırakın.
# =============================================================================
DEBUG=false
LOGSERVER_EXTERNAL_URL=http://localhost:8084
LOGSERVER_INTERNAL_URL=http://log-server:8084

# =============================================================================
# 📊 SELENIUM TRACKING
# ENV_TRACK_SUCCESS: true = log both found and not-found selectors
#                     false = only log not-found selectors (default)
# =============================================================================
ENV_TRACK_SUCCESS=false
